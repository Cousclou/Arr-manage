# PostgreSQL
POSTGRES_USER=mediaguard
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mediaguard
DATABASE_URL=postgresql+asyncpg://mediaguard:changeme@postgres:5432/mediaguard

# Redis
REDIS_URL=redis://redis:6379/0

# Sonarr
SONARR_URL=http://sonarr:8989
SONARR_API_KEY=

# Radarr
RADARR_URL=http://radarr:7878
RADARR_API_KEY=

# Prowlarr (monitoring indexeurs)
PROWLARR_URL=http://prowlarr:9696
PROWLARR_API_KEY=

# Pushover
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=

# Tâches (intervalles en secondes)
SONARR_MONITOR_INTERVAL=3600
RADARR_MONITOR_INTERVAL=3600
UPGRADE_CHECK_INTERVAL=7200
IMPORT_CHECK_INTERVAL=300
ANIME_CHECK_INTERVAL=600

# Seuil de taille pour recherche de versions légères (Go)
UPGRADE_SIZE_THRESHOLD_GB=15

# Tags Radarr à exclure (IDs séparés par des virgules)
RADARR_EXCLUDE_TAG_IDS=
